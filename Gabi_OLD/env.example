# GABI - Variáveis de ambiente (cópia para .env ou configure no Fly.io)
# Desenvolvimento: appsettings.Development.json já usa localhost; env só se precisar override.

# Conexão PostgreSQL (obrigatório em prod)
# ConnectionStrings__Default=Host=localhost;Port=5433;Database=gabi;Username=gabi;Password=gabi_dev_password

# Caminho do catálogo de fontes (API/Worker)
# GABI_SOURCES_PATH=sources_v2.yaml

# Opcionais (quando implementados)
# GABI_ELASTICSEARCH_URL=http://localhost:9200
# GABI_REDIS_URL=redis://localhost:6379/0

# Fly.io / Produção: use fly secrets set (não commitar valores reais)
# fly secrets set -a gabi-worker ConnectionStrings__Default="Host=..."
# fly secrets set -a gabi-api ConnectionStrings__Default="Host=..."
