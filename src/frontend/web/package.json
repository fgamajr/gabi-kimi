{
  "name": "gabi-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.jsx src/styles/index.css src/sw.js --bundle --splitting --format=esm --outdir=dist --entry-names=[name] --chunk-names=chunks/[name]-[hash] --minify --target=chrome113,safari16.4,firefox113 --loader:.svg=dataurl",
    "check": "npm run build && npm test",
    "test": "tsx --test tests/*.test.jsx"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "esbuild": "0.25.10",
    "jsdom": "24.1.3",
    "tsx": "4.20.5"
  }
}
