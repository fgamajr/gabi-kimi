{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
      }
    }
  },
  "Hangfire": {
    "RetryPolicy": {
      "Attempts": 3,
      "DelaysInSeconds": [2, 8, 30]
    }
  },
  "WorkerPool": {
    "EmbedWorkerCount": 3
  },
  "Gabi": {
    "SourcesPath": "sources_v2.yaml",
    "ElasticsearchUrl": "http://elasticsearch:9200",
    "RedisUrl": "redis://redis:6379/0",
    "DiscoveryAdapters": {
      "EnableWebCrawl": true,
      "EnableApiPagination": true
    }
  }
}
