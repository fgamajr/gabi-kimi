{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gabi": {
    "SourcesPath": "sources_v2.yaml",
    "Media": {
      "BasePath": "/workspace/",
      "AllowedUrlPatterns": [
        "https://*.youtube.com/*",
        "https://*.gov.br/*",
        "https://*.leg.br/*"
      ]
    }
  },
  "Jwt": {
    "Issuer": "GabiApi",
    "Audience": "GabiDashboard",
    "ExpiryHours": "24"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  }
}
