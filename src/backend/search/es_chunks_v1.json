{
  "settings": {
    "number_of_shards": 1,
    "number_of_replicas": 0,
    "analysis": {
      "analyzer": {
        "pt_analyzer": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "asciifolding"]
        }
      }
    }
  },
  "mappings": {
    "dynamic": false,
    "properties": {
      "chunk_id": { "type": "keyword" },
      "doc_id": { "type": "keyword" },
      "id_materia": { "type": "keyword" },
      "chunk_index": { "type": "integer" },
      "chunk_char_start": { "type": "integer" },
      "chunk_char_end": { "type": "integer" },
      "token_estimate": { "type": "integer" },
      "chunk_text": { "type": "text", "analyzer": "pt_analyzer" },
      "chunk_text_norm": { "type": "text", "analyzer": "pt_analyzer" },
      "heading_context": { "type": "text", "analyzer": "pt_analyzer" },
      "section": { "type": "keyword" },
      "publication_date": { "type": "date" },
      "issuing_organ": { "type": "keyword" },
      "art_type": { "type": "keyword" },
      "created_at": { "type": "date" },
      "metadata": { "type": "object", "enabled": true },
      "embedding": {
        "type": "dense_vector",
        "dims": 384,
        "index": true,
        "similarity": "cosine"
      }
    }
  }
}
