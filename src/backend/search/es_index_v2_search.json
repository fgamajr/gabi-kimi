{
  "settings": {
    "index": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "refresh_interval": "1s"
    },
    "analysis": {
      "filter": {
        "pt_br_stop": {
          "type": "stop",
          "stopwords": "_portuguese_"
        },
        "pt_br_stemmer": {
          "type": "stemmer",
          "language": "light_portuguese"
        }
      },
      "analyzer": {
        "pt_br_folded": {
          "tokenizer": "standard",
          "filter": [
            "lowercase",
            "asciifolding",
            "pt_br_stop",
            "pt_br_stemmer"
          ]
        }
      }
    }
  },
  "mappings": {
    "dynamic": false,
    "properties": {
      "logical_doc_id": { "type": "keyword" },
      "deterministic_hash": { "type": "keyword" },
      "pub_date": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd"
      },
      "organ": {
        "type": "keyword",
        "ignore_above": 1024
      },
      "section": { "type": "keyword" },
      "doc_type": {
        "type": "keyword",
        "ignore_above": 256
      },
      "edition_id": { "type": "keyword" },
      "edition_date": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd"
      },
      "title": {
        "type": "text",
        "analyzer": "pt_br_folded",
        "fields": {
          "keyword": {
            "type": "keyword",
            "ignore_above": 1024
          }
        }
      },
      "normalized_title": {
        "type": "keyword",
        "ignore_above": 1024
      },
      "body_text": {
        "type": "text",
        "analyzer": "pt_br_folded"
      },
      "search_all": {
        "type": "text",
        "analyzer": "pt_br_folded"
      },
      "text_language": { "type": "keyword" },
      "is_multipart": { "type": "boolean" },
      "multipart_seq": { "type": "integer" },
      "is_tombstone": { "type": "boolean" },
      "parse_quality_score": { "type": "float" },
      "primary_signer": {
        "type": "keyword",
        "ignore_above": 512
      },
      "signers_all_flat": {
        "type": "keyword",
        "ignore_above": 512
      },
      "has_multiple_signers": { "type": "boolean" },
      "signature_count": { "type": "integer" },
      "references_flat": {
        "type": "keyword",
        "ignore_above": 512
      },
      "reference_types": { "type": "keyword" },
      "reference_count": { "type": "integer" },
      "organization_path": {
        "type": "keyword",
        "ignore_above": 1024
      },
      "art_class_hierarchy": { "type": "keyword" },
      "document_number": {
        "type": "keyword",
        "ignore_above": 256
      },
      "document_year": { "type": "integer" },
      "affected_entities_normalized": {
        "type": "keyword",
        "ignore_above": 256
      },
      "source_url": {
        "type": "keyword",
        "ignore_above": 2048
      }
    }
  }
}
