{
  "settings": {
    "index": {
      "number_of_shards": 1,
      "number_of_replicas": 0,
      "refresh_interval": "30s"
    },
    "analysis": {
      "filter": {
        "pt_br_stop": { "type": "stop", "stopwords": "_portuguese_" },
        "pt_br_stemmer": { "type": "stemmer", "language": "light_portuguese" },
        "pt_br_synonym": {
          "type": "synonym",
          "lenient": true,
          "synonyms": [
            "portaria,port", "resolucao,res", "instrucao normativa,in",
            "decreto,dec", "acordao,ac", "tribunal de contas,tcu"
          ]
        }
      },
      "analyzer": {
        "pt_br_full": {
          "tokenizer": "standard",
          "filter": ["lowercase", "asciifolding", "pt_br_stop", "pt_br_stemmer", "pt_br_synonym"]
        },
        "pt_br_folded": {
          "tokenizer": "standard",
          "filter": ["lowercase", "asciifolding", "pt_br_stop", "pt_br_stemmer"]
        }
      }
    }
  },
  "mappings": {
    "dynamic": false,
    "properties": {
      "doc_id":              { "type": "keyword" },
      "source_type":         { "type": "keyword" },
      "authority_level":     { "type": "byte" },

      "tipo_norma":          { "type": "keyword" },
      "numero_norma":        { "type": "integer" },
      "ano_norma":           { "type": "integer" },

      "titulo": {
        "type": "text",
        "analyzer": "pt_br_full",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 512 } }
      },
      "assunto": {
        "type": "text",
        "analyzer": "pt_br_full"
      },
      "texto_norma": {
        "type": "text",
        "analyzer": "pt_br_folded"
      },
      "texto_anexo": {
        "type": "text",
        "analyzer": "pt_br_folded"
      },
      "search_all": {
        "type": "text",
        "analyzer": "pt_br_full"
      },

      "situacao":            { "type": "keyword" },
      "vigente":             { "type": "boolean" },
      "data_inicio_vigencia": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd"
      },
      "data_fim_vigencia": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd"
      },

      "origem":              { "type": "keyword" },
      "unidade_autora":      { "type": "keyword" },
      "numero_processo":     { "type": "keyword" },
      "link_btcu":           { "type": "keyword", "ignore_above": 2048 },
      "tema":                { "type": "keyword" },
      "norma_relacionada":   { "type": "text", "analyzer": "pt_br_folded" },

      "num_dou":             { "type": "keyword" },
      "secao_dou":           { "type": "keyword" },
      "pagina_dou":          { "type": "keyword" },
      "data_dou": {
        "type": "date",
        "format": "strict_date_optional_time||yyyy-MM-dd"
      },

      "source_csv":          { "type": "keyword" },
      "indexed_at": {
        "type": "date",
        "format": "strict_date_optional_time"
      },
      "embedding": {
        "type": "dense_vector",
        "dims": 1536,
        "index": true,
        "similarity": "cosine"
      },
      "embedding_status":    { "type": "keyword" }
    }
  }
}
