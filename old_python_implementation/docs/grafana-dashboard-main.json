      "id": 3,
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "avg_over_time(up{job=\"gabi-api\"}[$__range])",
          "refId": "A"
        }
      ],
      "title": "Availability (SLO: 99.9%)",
      "type": "stat"
    },
    {
