{
  "mapping_version": "1.0",
  "mapping_date": "2025-03-02",
  "sources": {
    "leiturajornal": {
      "name": "Leiturajornal",
      "type": "public_html_json",
      "url_pattern": "https://www.in.gov.br/leiturajornal?data={DD-MM-YYYY}&secao={section}",
      "auth_required": false,
      "coverage": {
        "do1": "2016-present",
        "do2": "2018-present",
        "do3": "2019-present"
      }
    },
    "inlabs": {
      "name": "INLabs",
      "type": "authenticated_xml_zip",
      "url_pattern": "https://inlabs.in.gov.br/index.php?p={YYYY-MM-DD}",
      "auth_required": true,
      "coverage": {
        "do1": "extensive_archive",
        "do2": "extensive_archive",
        "do3": "extensive_archive",
        "do1e": "extensive_archive",
        "do2e": "extensive_archive",
        "do3e": "extensive_archive"
      }
    }
  },
  "field_mappings": {
    "document_type": {
      "concept": "Type of legal document",
      "leiturajornal": "artType",
      "inlabs": "art_type",
      "transformation": "none",
      "priority": "high"
    },
    "title": {
      "concept": "Document title/identifier",
      "leiturajornal": "title",
      "inlabs": "identifica",
      "transformation": "normalize_whitespace",
      "priority": "high"
    },
    "page_number": {
      "concept": "Page in printed edition",
      "leiturajornal": "numberPage",
      "inlabs": "number_page",
      "transformation": "none",
      "priority": "high"
    },
    "edition_number": {
      "concept": "DOU edition number",
      "leiturajornal": "editionNumber",
      "inlabs": "edition_number",
      "transformation": "none",
      "priority": "high"
    },
    "publication_date": {
      "concept": "Date of publication",
      "leiturajornal": "pubDate",
      "inlabs": "pub_date",
      "transformation": "parse_date_ddmmyyyy",
      "priority": "high"
    },
    "publication_section": {
      "concept": "DOU section",
      "leiturajornal": "pubName",
      "inlabs": "pub_name",
      "transformation": "none",
      "priority": "high"
    },
    "organization": {
      "concept": "Issuing organization hierarchy",
      "leiturajornal": "hierarchyStr",
      "inlabs": "art_category",
      "transformation": "normalize_path",
      "priority": "medium"
    },
    "content": {
      "concept": "Full document text",
      "leiturajornal": "content",
      "inlabs": "texto",
      "transformation": "strip_html",
      "priority": "high"
    },
    "url_slug": {
      "concept": "URL-friendly identifier",
      "leiturajornal": "urlTitle",
      "inlabs": null,
      "transformation": "generate_from_title",
      "priority": "medium"
    },
    "unique_id": {
      "concept": "Official unique identifier",
      "leiturajornal": null,
      "inlabs": "id_materia",
      "transformation": "none",
      "priority": "high",
      "note": "INLabs provides 8-digit official ID; leiturajornal has no equivalent"
    },
    "hierarchy_code": {
      "concept": "Machine-readable hierarchy",
      "leiturajornal": "hierarchyLevelSize",
      "inlabs": "art_class",
      "transformation": "art_class_to_depth",
      "priority": "low"
    },
    "pdf_page": {
      "concept": "PDF page reference",
      "leiturajornal": null,
      "inlabs": "pdf_page",
      "transformation": "none",
      "priority": "low"
    },
    "summary": {
      "concept": "Document summary/ementa",
      "leiturajornal": null,
      "inlabs": "ementa",
      "transformation": "none",
      "priority": "medium",
      "note": "Often empty in both sources"
    },
    "extra_edition": {
      "concept": "Extraordinary edition flag",
      "leiturajornal": null,
      "inlabs": "art_notes",
      "transformation": "check_equals_extra",
      "priority": "low"
    }
  },
  "matching_strategies": {
    "primary": {
      "name": "High Confidence Match",
      "fields": ["art_type", "number_page", "edition_number"],
      "weights": {
        "art_type": 2,
        "number_page": 3,
        "edition_number": 1
      },
      "min_score": 5,
      "description": "Match on document type, page, and edition"
    },
    "secondary": {
      "name": "Medium Confidence Match",
      "fields": ["title", "organization", "art_type"],
      "weights": {
        "title_similarity": 5,
        "organization_overlap": 2,
        "art_type": 2
      },
      "min_score": 5,
      "description": "Fuzzy match on title and organization"
    },
    "tertiary": {
      "name": "Low Confidence Match",
      "fields": ["art_type"],
      "weights": {
        "art_type": 2
      },
      "min_score": 2,
      "description": "Type-only match for verification"
    }
  },
  "canonical_schema": {
    "document": {
      "id": "uuid_v7",
      "source_id": "string",
      "external_id": "string (id_materia if available)",
      "document_type": "string (normalized)",
      "title": "string",
      "content": "text",
      "publication_date": "date",
      "edition_number": "string",
      "page_number": "string",
      "section": "string (DO1/DO2/DO3)",
      "issuing_organization": "string",
      "source_url": "string",
      "provenance": "enum (inlabs/leiturajornal/both)"
    }
  },
  "recommendations": {
    "primary_source": "inlabs",
    "fallback_source": "leiturajornal",
    "public_access": "leiturajornal",
    "legal_reference": "inlabs",
    "text_analysis": "leiturajornal",
    "archival_storage": "inlabs",
    "quick_verification": "leiturajornal"
  }
}
