# =============================================================================
# GABI Fly.io Secrets Template
# Copy this file and fill in your values, then source it before running scripts
# =============================================================================

# =============================================================================
# DATABASE
# =============================================================================
# Fly Postgres connection string (get from: fly postgres connect --app gabi-db)
export GABI_DATABASE_URL="postgresql+asyncpg://username:password@gabi-db.fly.dev:5432/gabi?sslmode=require"

# =============================================================================
# REDIS
# =============================================================================
# Upstash Redis connection string (get from: fly ext redis status --app gabi-api)
export GABI_REDIS_URL="rediss://default:password@host.upstash.io:6379"
export GABI_REDIS_PASSWORD=""

# =============================================================================
# ELASTICSEARCH (Elastic Cloud)
# =============================================================================
# Create deployment at https://cloud.elastic.co/
# Choose region: Brazil (São Paulo) for lowest latency
export GABI_ELASTICSEARCH_URL="https://your-deployment.es.us-east-1.aws.found.io:9243"
export GABI_ELASTICSEARCH_USERNAME="elastic"
export GABI_ELASTICSEARCH_PASSWORD="your-elastic-cloud-password"

# =============================================================================
# OPENAI (for embeddings in production)
# =============================================================================
# Alternative to local TEI - more scalable, no model management
export OPENAI_API_KEY="sk-..."

# =============================================================================
# AUTHENTICATION (Keycloak)
# =============================================================================
export GABI_JWT_ISSUER="https://auth.tcu.gov.br/realms/tcu"
export GABI_JWT_AUDIENCE="gabi-api"
export GABI_JWT_JWKS_URL="https://auth.tcu.gov.br/realms/tcu/protocol/openid-connect/certs"

# =============================================================================
# OPTIONAL: Additional security
# =============================================================================
export GABI_SECRET_KEY="$(openssl rand -hex 32)"

# =============================================================================
# LOCAL MIGRATION SETTINGS
# =============================================================================
export LOCAL_ES_URL="http://localhost:9200"
export LOCAL_DB_URL="postgresql://gabi:gabi_dev_password@localhost:5432/gabi"
export ES_INDEX="gabi_documents_v1"
