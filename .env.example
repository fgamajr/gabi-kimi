# =============================================================================
# GABI - Environment Variables Example
# =============================================================================
# Copie este arquivo para .env e ajuste os valores conforme necessário
# ATENÇÃO: Nunca commite o arquivo .env com valores reais!
# =============================================================================

# =============================================================================
# Ambiente
# =============================================================================
GABI_ENVIRONMENT=local
GABI_DEBUG=true
GABI_LOG_LEVEL=debug

# =============================================================================
# PostgreSQL (pgvector)
# =============================================================================
# URL completa de conexão (usada em produção)
GABI_DATABASE_URL=postgresql+asyncpg://gabi:gabi@localhost:5432/gabi

# Configurações de pool (opcional)
GABI_DATABASE_POOL_SIZE=10
GABI_DATABASE_MAX_OVERFLOW=20
GABI_DATABASE_POOL_TIMEOUT=30
GABI_DATABASE_ECHO=false

# =============================================================================
# Elasticsearch
# =============================================================================
GABI_ELASTICSEARCH_URL=http://localhost:9200
GABI_ELASTICSEARCH_INDEX=gabi_documents_v1
GABI_ELASTICSEARCH_TIMEOUT=30
GABI_ELASTICSEARCH_MAX_RETRIES=3
# Descomente para autenticação (produção)
# GABI_ELASTICSEARCH_USERNAME=elastic
# GABI_ELASTICSEARCH_PASSWORD=changeme

# =============================================================================
# Redis
# =============================================================================
GABI_REDIS_URL=redis://localhost:6379/0
GABI_REDIS_DLQ_DB=1
GABI_REDIS_CACHE_DB=2
GABI_REDIS_LOCK_DB=3

# =============================================================================
# Embeddings (TEI - Text Embeddings Inference)
# =============================================================================
# ⚠️ ATENÇÃO: embeddings_dimensions é IMUTÁVEL (384)
GABI_EMBEDDINGS_URL=http://localhost:8080
GABI_EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
GABI_EMBEDDINGS_DIMENSIONS=384
GABI_EMBEDDINGS_BATCH_SIZE=32
GABI_EMBEDDINGS_TIMEOUT=60
GABI_EMBEDDINGS_MAX_RETRIES=3
GABI_EMBEDDINGS_CIRCUIT_BREAKER_THRESHOLD=5
GABI_EMBEDDINGS_CIRCUIT_BREAKER_TIMEOUT=60

# =============================================================================
# Pipeline de Ingestão
# =============================================================================
GABI_PIPELINE_MAX_MEMORY_MB=3584
GABI_PIPELINE_FETCH_TIMEOUT=60
GABI_PIPELINE_FETCH_MAX_RETRIES=3
GABI_PIPELINE_FETCH_MAX_SIZE_MB=100
GABI_PIPELINE_CHUNK_MAX_TOKENS=512
GABI_PIPELINE_CHUNK_OVERLAP_TOKENS=50
GABI_PIPELINE_CONCURRENCY=3
GABI_PIPELINE_CHECKPOINT_INTERVAL=100

# =============================================================================
# Busca (RRF - Reciprocal Rank Fusion)
# =============================================================================
GABI_SEARCH_RRF_K=60
GABI_SEARCH_DEFAULT_LIMIT=10
GABI_SEARCH_MAX_LIMIT=100
GABI_SEARCH_BM25_WEIGHT=1.0
GABI_SEARCH_VECTOR_WEIGHT=1.0
GABI_SEARCH_TIMEOUT_MS=5000

# =============================================================================
# Autenticação JWT (Keycloak TCU)
# =============================================================================
# Para desenvolvimento local, defina GABI_AUTH_ENABLED=false
# Para produção, configure o Keycloak TCU
GABI_AUTH_ENABLED=false
GABI_JWT_ISSUER=https://auth.tcu.gov.br/realms/tcu
GABI_JWT_AUDIENCE=gabi-api
GABI_JWT_JWKS_URL=https://auth.tcu.gov.br/realms/tcu/protocol/openid-connect/certs
GABI_JWT_ALGORITHM=RS256
GABI_JWT_JWKS_CACHE_MINUTES=5
# Caminhos públicos (não requerem auth) - formato JSON array
GABI_AUTH_PUBLIC_PATHS=["/health", "/metrics", "/docs", "/openapi.json"]

# =============================================================================
# Rate Limiting
# =============================================================================
GABI_RATE_LIMIT_ENABLED=true
GABI_RATE_LIMIT_REQUESTS_PER_MINUTE=60
GABI_RATE_LIMIT_BURST=10
GABI_RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# MCP (Model Context Protocol) Server
# =============================================================================
GABI_MCP_ENABLED=true
GABI_MCP_PORT=8001
GABI_MCP_AUTH_REQUIRED=true

# =============================================================================
# Crawler
# =============================================================================
GABI_CRAWLER_HEADLESS=true
GABI_CRAWLER_DELAY_SECONDS=1.0
GABI_CRAWLER_RESPECT_ROBOTS=true
GABI_CRAWLER_MAX_PAGES=1000
GABI_CRAWLER_MAX_DEPTH=3
GABI_CRAWLER_TIMEOUT_SECONDS=30

# =============================================================================
# Governança de Dados
# =============================================================================
GABI_AUDIT_ENABLED=true
GABI_AUDIT_RETENTION_DAYS=2555
GABI_QUALITY_ENABLED=true
GABI_LINEAGE_ENABLED=true

# =============================================================================
# Fontes de Dados
# =============================================================================
GABI_SOURCES_PATH=sources.yaml
GABI_SOURCES_VALIDATION_STRICT=true

# =============================================================================
# API Server
# =============================================================================
GABI_API_HOST=0.0.0.0
GABI_API_PORT=8000
GABI_API_WORKERS=1
GABI_API_RELOAD=false

# =============================================================================
# CORS
# =============================================================================
# Formato: JSON array de strings
GABI_CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://127.0.0.1:3000"]
GABI_CORS_ALLOW_CREDENTIALS=true
GABI_CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE"]
GABI_CORS_ALLOW_HEADERS=["Authorization", "Content-Type", "X-Request-ID"]

# =============================================================================
# Variáveis para Docker Compose Local
# =============================================================================
# Estas variáveis são usadas apenas pelo docker-compose.local.yml
POSTGRES_USER=gabi
POSTGRES_PASSWORD=gabi
POSTGRES_DB=gabi

# Flower (Celery monitoring)
FLOWER_BASIC_AUTH=gabi:gabi
