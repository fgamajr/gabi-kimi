# Last verified: 2026-03-06
# GABI local environment template
# Copy to .env and fill in the values you actually use.
#   cp .env.example .env

# Container-first environment template.
# The only host dependency should be Docker and Docker Compose.
GABI_HOST_DATA_ROOT=/mnt/HC_Volume_105154890

# PostgreSQL (legacy / optional, if you add a postgres container)
# Preferred override for scripts that accept a full DSN.
PG_DSN=

# libpq-style fallback used by web_server.py, mcp_server.py, bm25_indexer.py, and backfill scripts.
PGHOST=postgres
PGPORT=5432
PGDATABASE=gabi
PGUSER=gabi
PGPASSWORD=gabi

# Alternative fallback names used by es_indexer.py, embedding_pipeline.py, and src/backend/search/adapters.py.
GABI_POSTGRES_HOST=postgres
GABI_POSTGRES_PORT=5432
GABI_POSTGRES_DB=gabi
GABI_POSTGRES_USER=gabi
GABI_POSTGRES_PASSWORD=gabi

# Search backend selector: pg | es | hybrid
SEARCH_BACKEND=hybrid

# Primary backend runtime defaults
MONGO_STRING=mongodb://mongo:27017/gabi_dou
DB_NAME=gabi_dou
DOU_DATA_PATH=/data/gabi_dou
ICLOUD_DATA_PATH=/data/gabi_dou
PIPELINE_TMP=/data/gabi_dou/pipeline
MONGO_AUTH_ENABLED=false
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
MONGO_APP_USERNAME=gabi_app
MONGO_APP_PASSWORD=

# Elasticsearch document and chunk indexes
ES_URL=http://elasticsearch:9200
ES_INDEX=gabi_documents_v3
ES_ALIAS=gabi_documents
ES_CHUNKS_INDEX=gabi_chunks_v1
ES_SYNC_CURSOR_PATH=/data/gabi_dou/es_sync_cursor.json
ES_USERNAME=
ES_PASSWORD=
ES_VERIFY_TLS=false
ES_TIMEOUT_SEC=20

# Hybrid retrieval controls
HYBRID_LEXICAL_K=80
HYBRID_VECTOR_K=80
HYBRID_NUM_CANDIDATES=240
HYBRID_RRF_K=60
RERANK_PROVIDER=basic
RERANK_TOP_N=25

# 3-stage hybrid pipeline (BM25 + kNN + neural reranker)
VECTOR_SEARCH_ENABLED=false
EMBED_SERVER_URL=http://host.docker.internal:8900
RERANKER_ENABLED=false
# Base URL is preferred. A full /v1/rerank endpoint also works.
RERANKER_URL=http://host.docker.internal:8902
RERANKER_TOP_K=50
RERANKER_TIMEOUT=5.0
RERANKER_MAX_DOCS=50
RERANKER_MAX_DOC_CHARS=2200
RERANKER_UPSTREAM_URL=http://host.docker.internal:8080/engines/vllm/rerank
RERANKER_UPSTREAM_TIMEOUT=1.5
RERANKER_MAX_CONCURRENCY=2
RERANKER_MODEL=ai/qwen3-reranker-vllm:0.6B
RERANKER_BIND_HOST=0.0.0.0
RERANKER_PORT=8902

# Embeddings / vector pipeline
# EMBED_PROVIDER: hash | openai-compatible
EMBED_PROVIDER=openai-compatible
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=384
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
OPENAI_API_KEY=
EMBED_TIMEOUT_SEC=30
EMBED_VERIFY_TLS=true
EMBED_MAX_RETRIES=6
EMBED_RETRY_BASE_SEC=1.5

# Redis (legacy / optional, if you add a redis container)
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=gabi
TOP_SEARCH_MIN_QUERY_LEN=3
TOP_SEARCH_MAX_QUERY_LEN=120
TOP_SEARCH_DAY_TTL_SEC=1209600
TOP_SEARCH_WEEK_TTL_SEC=9676800
SUGGEST_CACHE_TTL_SEC=120
SEARCH_RESULT_CACHE_TTL_SEC=180
GABI_ANALYTICS_CACHE_REFRESH_ON_STARTUP=false
GABI_ANALYTICS_CACHE_STALE_HOURS=6
WORKER_URL=http://worker:8081
WORKER_BATCH_SIZE=1000
WORKER_POLL_INTERVAL_SEC=30
REGISTRY_DB_PATH=ops/data/registry.db

# Optional Qwen chat proxy used by /api/chat
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# MCP server → FastAPI backend connection
GABI_API_URL=http://localhost:8001
GABI_API_TOKEN=
# MCP SSE transport auth (for remote MCP clients connecting via HTTP)
MCP_AUTH_TOKEN=

# Web auth / security hardening
# One or more Bearer tokens, comma-separated. Supports raw tokens or label:token pairs.
# Example: mcp:secret123,cli:othersecret
GABI_API_TOKENS=
# Optional comma-separated token labels that should also receive the admin role.
GABI_ADMIN_TOKEN_LABELS=
GABI_AUTH_SECRET=
GABI_SESSION_COOKIE=gabi_session
GABI_SESSION_TTL_SEC=43200
GABI_SESSION_SAMESITE=lax
# Email verification (A1): Resend. Without RESEND_API_KEY, verification emails are not sent (register still works).
# RESEND_API_KEY=
# RESEND_FROM=GABI Search <noreply@yourdomain.com>
# Optional: public app URL for verification links in emails (defaults to request.base_url).
# GABI_APP_URL=https://your-app.fly.dev
GABI_SERVE_FRONTEND=true
GABI_ALLOWED_HOSTS=frontend,backend,localhost,127.0.0.1
GABI_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
GABI_CORS_ALLOW_CREDENTIALS=false
GABI_EXPOSE_API_DOCS=true
GABI_PUBLIC_HEALTH_DETAILS=false
GABI_ENABLE_SECURITY_HEADERS=true
GABI_HSTS_MAX_AGE=31536000
GABI_HSTS_INCLUDE_SUBDOMAINS=true
GABI_HSTS_PRELOAD=false
GABI_FRAME_OPTIONS=DENY
GABI_REFERRER_POLICY=strict-origin-when-cross-origin
GABI_PERMISSIONS_POLICY=accelerometer=(), autoplay=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), publickey-credentials-get=(), usb=()
GABI_COOP=same-origin
GABI_CORP=same-origin
GABI_CSP=default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: https:; style-src 'self'; script-src 'self' 'unsafe-inline'; connect-src 'self'; form-action 'self'; upgrade-insecure-requests
GABI_MEDIA_ROOT=
GABI_MAX_BODY_SIZE_BYTES=2097152
GABI_SECURITY_BLOCK_TIME_SEC=3600
GABI_SECURITY_SCAN_THRESHOLD=6
GABI_CHAT_CACHE_TTL_SEC=300
GABI_CHAT_SCORE_TTL_SEC=3600
GABI_CHAT_BLOCK_THRESHOLD=10
GABI_CHAT_BLOCK_TIME_SEC=3600

# Dev-only multi-agent convergence MCP
# Alibaba-hosted Kimi/Qwen/GLM share the same DashScope-compatible key.
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# Admin upload: Tigris (Fly) or MinIO (local dev). Leave unset to disable upload.
# Local dev with ops/local/docker-compose.yml (MinIO): uncomment block below; create bucket "gabi-dou-uploads" once at http://localhost:9001 (minioadmin/minioadmin).
# AWS_ENDPOINT_URL_S3=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# BUCKET_NAME=gabi-dou-uploads
# S3_PATH_STYLE=true

# Optional INLabs cookie for download paths that require it
GABI_INLABS_COOKIE=

# Sentry (optional). Set in Fly secrets for web/worker; VITE_ for frontend build.
# SENTRY_DSN_BACKEND=
# SENTRY_DSN_WORKER=
# VITE_SENTRY_DSN_FRONTEND=

