# Last verified: 2026-03-06
# GABI local environment template
# Copy to .env and fill in the values you actually use.
#   cp .env.example .env

# PostgreSQL
# Preferred override for scripts that accept a full DSN.
PG_DSN=

# libpq-style fallback used by web_server.py, mcp_server.py, bm25_indexer.py, and backfill scripts.
PGHOST=localhost
PGPORT=5433
PGDATABASE=gabi
PGUSER=gabi
PGPASSWORD=gabi

# Alternative fallback names used by es_indexer.py, embedding_pipeline.py, and src/backend/search/adapters.py.
GABI_POSTGRES_HOST=localhost
GABI_POSTGRES_PORT=5433
GABI_POSTGRES_DB=gabi
GABI_POSTGRES_USER=gabi
GABI_POSTGRES_PASSWORD=gabi

# Search backend selector: pg | es | hybrid
SEARCH_BACKEND=hybrid

# Elasticsearch document and chunk indexes
ES_URL=http://localhost:9200
ES_INDEX=gabi_documents_v1
ES_ALIAS=gabi_documents
ES_CHUNKS_INDEX=gabi_chunks_v1
ES_USERNAME=
ES_PASSWORD=
ES_VERIFY_TLS=false
ES_TIMEOUT_SEC=20

# Hybrid retrieval controls
HYBRID_LEXICAL_K=80
HYBRID_VECTOR_K=80
HYBRID_NUM_CANDIDATES=240
HYBRID_RRF_K=60
RERANK_PROVIDER=basic
RERANK_TOP_N=25

# Embeddings / vector pipeline
# EMBED_PROVIDER: hash | openai-compatible
EMBED_PROVIDER=openai-compatible
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=384
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
OPENAI_API_KEY=
EMBED_TIMEOUT_SEC=30
EMBED_VERIFY_TLS=true
EMBED_MAX_RETRIES=6
EMBED_RETRY_BASE_SEC=1.5

# Redis (query-assist + admin upload job queue; worker consumes from here)
REDIS_URL=redis://localhost:6380/0
REDIS_PREFIX=gabi
TOP_SEARCH_MIN_QUERY_LEN=3
TOP_SEARCH_MAX_QUERY_LEN=120
TOP_SEARCH_DAY_TTL_SEC=1209600
TOP_SEARCH_WEEK_TTL_SEC=9676800
SUGGEST_CACHE_TTL_SEC=120
SEARCH_RESULT_CACHE_TTL_SEC=180
GABI_ANALYTICS_CACHE_REFRESH_ON_STARTUP=false
GABI_ANALYTICS_CACHE_STALE_HOURS=6
WORKER_URL=http://127.0.0.1:8081
REGISTRY_DB_PATH=ops/data/registry.db

# Optional Qwen chat proxy used by /api/chat
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# Web auth / security hardening
# One or more Bearer tokens, comma-separated. Supports raw tokens or label:token pairs.
GABI_API_TOKENS=
# Optional comma-separated token labels that should also receive the admin role.
GABI_ADMIN_TOKEN_LABELS=
GABI_AUTH_SECRET=
GABI_SESSION_COOKIE=gabi_session
GABI_SESSION_TTL_SEC=43200
GABI_SESSION_SAMESITE=lax
GABI_SERVE_FRONTEND=true
GABI_ALLOWED_HOSTS=localhost,127.0.0.1
GABI_CORS_ORIGINS=
GABI_MEDIA_ROOT=
GABI_MAX_BODY_SIZE_BYTES=2097152
GABI_SECURITY_BLOCK_TIME_SEC=3600
GABI_SECURITY_SCAN_THRESHOLD=6
GABI_CHAT_CACHE_TTL_SEC=300
GABI_CHAT_SCORE_TTL_SEC=3600
GABI_CHAT_BLOCK_THRESHOLD=10
GABI_CHAT_BLOCK_TIME_SEC=3600

# Dev-only multi-agent convergence MCP
# Alibaba-hosted Kimi/Qwen/GLM share the same DashScope-compatible key.
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# Admin upload: Tigris (Fly) or MinIO (local dev). Leave unset to disable upload.
# Local dev with ops/local/docker-compose.yml (MinIO): uncomment block below; create bucket "gabi-dou-uploads" once at http://localhost:9001 (minioadmin/minioadmin).
# AWS_ENDPOINT_URL_S3=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# BUCKET_NAME=gabi-dou-uploads
# S3_PATH_STYLE=true

# Optional INLabs cookie for download paths that require it
GABI_INLABS_COOKIE=
