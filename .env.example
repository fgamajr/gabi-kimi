# GABI - Configuração Local (Docker + Host)
# Copie para .env.local e preencha os secrets.
# Exemplo:
#   cp .env.example .env.local

# Database (conecta ao container Docker na porta 5433)
GABI_POSTGRES_PORT=5433
ConnectionStrings__Default=Host=localhost;Port=5433;Database=gabi;Username=gabi;Password=gabi_dev_password

# Elasticsearch
GABI_ELASTICSEARCH_URL=http://localhost:9200

# Redis
GABI_REDIS_URL=redis://localhost:6379/0

# Application
GABI_DEBUG=true
GABI_ENVIRONMENT=local
GABI_LOG_LEVEL=info
GABI_AUTH_ENABLED=false
GABI_SOURCES_PATH=sources_v2.yaml

# Resource tuning
GABI_ES_HEAP=512m
GABI_TEI_MEM_LIMIT=6G
GABI_TEI_MEM_RESERVE=1G
GABI_TEI_WORKERS=2
GABI_REDIS_MAXMEM=256mb

# Secrets / External APIs
GITHUB_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
GABI_INLABS_COOKIE=
