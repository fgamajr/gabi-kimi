# GABI – Configuração Local
# Copie para .env e preencha os valores.
#   cp .env.example .env

# PostgreSQL (Docker appliance, porta 5433)
GABI_POSTGRES_HOST=localhost
GABI_POSTGRES_PORT=5433
GABI_POSTGRES_DB=gabi
GABI_POSTGRES_USER=gabi
GABI_POSTGRES_PASSWORD=gabi_dev_password

# Application
GABI_DEBUG=true
GABI_LOG_LEVEL=info
GABI_SOURCES_PATH=sources_v3.yaml

# Search backend selector: pg | es | hybrid
SEARCH_BACKEND=hybrid

# Elasticsearch
ES_URL=http://localhost:9200
ES_INDEX=gabi_documents_v1
ES_ALIAS=gabi_documents
ES_USERNAME=
ES_PASSWORD=
ES_VERIFY_TLS=false
ES_TIMEOUT_SEC=20
ES_CHUNKS_INDEX=gabi_chunks_v1
HYBRID_LEXICAL_K=80
HYBRID_VECTOR_K=80
HYBRID_NUM_CANDIDATES=240
HYBRID_RRF_K=60
RERANK_PROVIDER=basic
RERANK_TOP_N=25

# Embeddings / Vector index (Phase 2)
# EMBED_PROVIDER: hash (dev) | openai-compatible
EMBED_PROVIDER=openai-compatible
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
# Optional fallback used when EMBED_API_KEY is empty.
OPENAI_API_KEY=
EMBED_TIMEOUT_SEC=30
EMBED_VERIFY_TLS=true
EMBED_MAX_RETRIES=6
EMBED_RETRY_BASE_SEC=1.5
USE_CONTEXTUAL_EMBEDDINGS=true

# Redis query-assist signals (autocomplete cache + top searches)
REDIS_URL=redis://localhost:6380/0
REDIS_PREFIX=gabi
SEARCH_ANALYTICS_ENABLED=true
TOP_SEARCH_MIN_QUERY_LEN=3
TOP_SEARCH_MAX_QUERY_LEN=120
SUGGEST_CACHE_TTL_SEC=120

# INLabs (bulk ZIP download)
GABI_INLABS_COOKIE=
