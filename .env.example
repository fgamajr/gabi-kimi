# Last verified: 2026-03-06
# GABI local environment template
# Copy to .env and fill in the values you actually use.
#   cp .env.example .env

# PostgreSQL
# Preferred override for scripts that accept a full DSN.
PG_DSN=

# libpq-style fallback used by web_server.py, mcp_server.py, bm25_indexer.py, and backfill scripts.
PGHOST=localhost
PGPORT=5433
PGDATABASE=gabi
PGUSER=gabi
PGPASSWORD=gabi

# Alternative fallback names used by es_indexer.py, embedding_pipeline.py, and src/backend/search/adapters.py.
GABI_POSTGRES_HOST=localhost
GABI_POSTGRES_PORT=5433
GABI_POSTGRES_DB=gabi
GABI_POSTGRES_USER=gabi
GABI_POSTGRES_PASSWORD=gabi

# Search backend selector: pg | es | hybrid
SEARCH_BACKEND=hybrid

# Elasticsearch document and chunk indexes
ES_URL=http://localhost:9200
ES_INDEX=gabi_documents_v1
ES_ALIAS=gabi_documents
ES_CHUNKS_INDEX=gabi_chunks_v1
ES_USERNAME=
ES_PASSWORD=
ES_VERIFY_TLS=false
ES_TIMEOUT_SEC=20

# Hybrid retrieval controls
HYBRID_LEXICAL_K=80
HYBRID_VECTOR_K=80
HYBRID_NUM_CANDIDATES=240
HYBRID_RRF_K=60
RERANK_PROVIDER=basic
RERANK_TOP_N=25

# Embeddings / vector pipeline
# EMBED_PROVIDER: hash | openai-compatible
EMBED_PROVIDER=openai-compatible
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=384
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
OPENAI_API_KEY=
EMBED_TIMEOUT_SEC=30
EMBED_VERIFY_TLS=true
EMBED_MAX_RETRIES=6
EMBED_RETRY_BASE_SEC=1.5

# Redis query-assist signals
REDIS_URL=redis://localhost:6380/0
REDIS_PREFIX=gabi
TOP_SEARCH_MIN_QUERY_LEN=3
TOP_SEARCH_MAX_QUERY_LEN=120
TOP_SEARCH_DAY_TTL_SEC=1209600
TOP_SEARCH_WEEK_TTL_SEC=9676800
SUGGEST_CACHE_TTL_SEC=120

# Optional Qwen chat proxy used by /api/chat
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# Dev-only multi-agent convergence MCP
# Alibaba-hosted Kimi/Qwen/GLM share the same DashScope-compatible key.
DASHSCOPE_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1

# Optional INLabs cookie for download paths that require it
GABI_INLABS_COOKIE=
