# GABI Environment Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env with real credentials!
#
# Setup:
#   cp .env.example .env
#   # Edit .env with your actual values

# Database
GABI_DATABASE_URL=postgresql+asyncpg://gabi:YOUR_DB_PASSWORD@YOUR_HOST:YOUR_DB_PORT/gabi

# Elasticsearch
GABI_ELASTICSEARCH_URL=http://YOUR_HOST:YOUR_ES_PORT

# Redis
GABI_REDIS_URL=redis://YOUR_HOST:YOUR_REDIS_PORT/0

# Application
GABI_DEBUG=true
GABI_ENVIRONMENT=local
GABI_LOG_LEVEL=info

# Security (desabilitado para local dev)
GABI_JWT_ALGORITHM=RS256

# CORS
GABI_CORS_ORIGINS=http://YOUR_HOST:3000,http://YOUR_HOST:8000,http://YOUR_HOST:5173

# Paths
GABI_SOURCES_PATH=sources.yaml

# Feature flags via environment
GABI_AUTH_ENABLED=false

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================
#
# Core Connection Settings:
# - GABI_DATABASE_URL: PostgreSQL connection string
#   Format: postgresql+asyncpg://user:password@host:port/database
#
# - GABI_ELASTICSEARCH_URL: Elasticsearch URL
#   Format: http://host:port
#
# - GABI_REDIS_URL: Redis connection string
#   Format: redis://host:port/db
#
# Application Settings:
# - GABI_ENVIRONMENT: Environment name (local, development, staging, production)
# - GABI_SECRET_KEY: JWT signing key (generate strong random for production)
# - GABI_DEBUG: Enable debug mode (true/false) - set false in production
#
# Optional Settings:
# - GABI_JWT_ALGORITHM: JWT algorithm (default: RS256)
# - GABI_CORS_ORIGINS: Comma-separated list of allowed CORS origins
# - GABI_LOG_LEVEL: Logging level (debug, info, warning, error)
# - GABI_AUTH_ENABLED: Enable authentication (true/false)
# - GABI_SOURCES_PATH: Path to sources configuration file
#
# =============================================================================
# KUBERNETES NOTE
# =============================================================================
# K8S deployments use non-prefixed variable names (e.g., DATABASE_URL instead
# of GABI_DATABASE_URL). The application should handle both naming conventions.
# See k8s/base/configmap.yaml for K8S-specific configuration.
# =============================================================================
