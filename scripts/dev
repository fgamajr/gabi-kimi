#!/bin/bash
# GABI - Single entry point for development commands
# Usage: ./scripts/dev [setup|infra|app|db] [subcommand...]

set -e
GABI_SCRIPTS="$(cd "$(dirname "$0")" && pwd)"
GABI_ROOT="$(cd "$GABI_SCRIPTS/.." && pwd)"
export GABI_SCRIPTS GABI_ROOT

show_help() {
    echo "GABI - Development CLI"
    echo ""
    echo "Usage: ./scripts/dev <command> [options]"
    echo ""
    echo "Commands:"
    echo "  setup              One-time setup (deps, infra, db)"
    echo "  destroy            Destroy everything (alias for infra destroy)"
    echo "  infra up           Start Docker (Postgres, Elastic, Redis)"
    echo "  infra down         Stop Docker (keep volumes)"
    echo "  infra destroy      Stop Docker and delete all data"
    echo "  app up             Start API (foreground until Ctrl+C)"
    echo "  app down           Stop API (foreground mode)"
    echo "  app start          Start API (background / detached)"
    echo "  app stop           Stop API (background mode)"
    echo "  app status         Show running status of API + Infra"
    echo "  app logs [api]     Tail application logs"
    echo "  db apply           Apply pending migrations"
    echo "  db create <Name>   Create new migration"
    echo "  db status          List migrations"
    echo "  db reset           Drop DB and re-apply (destructive)"
    echo "  help               This message"
    echo ""
    echo "Examples:"
    echo "  ./scripts/dev setup"
    echo "  ./scripts/dev infra up"
    echo "  ./scripts/dev app up"
    echo "  ./scripts/dev db create AddDocumentsTable"
    echo ""
}

cmd="$1"
sub="$2"
shift 2 2>/dev/null || true

case "$cmd" in
    setup)
        "$GABI_SCRIPTS/setup.sh"
        ;;
    destroy)
        "$GABI_SCRIPTS/infra-destroy.sh"
        ;;
    infra)
        case "$sub" in
            up)      "$GABI_SCRIPTS/infra-up.sh" ;;
            down)    "$GABI_SCRIPTS/infra-down.sh" ;;
            destroy) "$GABI_SCRIPTS/infra-destroy.sh" ;;
            *)       echo "Usage: dev infra up|down|destroy"; exit 1 ;;
        esac
        ;;
    app)
        case "$sub" in
            up)         "$GABI_SCRIPTS/app-up.sh" ;;
            down)       "$GABI_SCRIPTS/app-down.sh" ;;
            start)      "$GABI_SCRIPTS/app-start-detached.sh" ;;
            stop)       "$GABI_SCRIPTS/app-stop.sh" ;;
            status)     "$GABI_SCRIPTS/app-status.sh" ;;
            logs)       "$GABI_SCRIPTS/app-logs.sh" "${1:-all}" ;;
            *)          echo "Usage: dev app up|down|start|stop|status|logs [api]"; exit 1 ;;
        esac
        ;;
    db)
        case "$sub" in
            apply)  "$GABI_SCRIPTS/db-migrate.sh" apply ;;
            create) "$GABI_SCRIPTS/db-migrate.sh" create "$1" ;;
            status) "$GABI_SCRIPTS/db-migrate.sh" status ;;
            reset)  "$GABI_SCRIPTS/db-migrate.sh" reset ;;
            *)      echo "Usage: dev db apply|create <Name>|status|reset"; exit 1 ;;
        esac
        ;;
    help|--help|-h|"")
        show_help
        ;;
    *)
        echo "Unknown command: $cmd"
        show_help
        exit 1
        ;;
esac
